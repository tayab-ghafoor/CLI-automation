# Email Configuration (For notifications and alerts)
# EMAIL_SENDER - Your Gmail address for sending emails (must enable App Password)
# EMAIL_PASSWORD - Your Gmail App Password (not your regular password)
# EMAIL_RECIPIENT - Default recipient for system alerts (optional, system sends to user's email)
# SMTP_HOST/SMTP_PORT/SMTP_USE_SSL/SMTP_USE_TLS - Optional custom SMTP settings
#
# How to set up App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication
# 3. Go to App Passwords section
# 4. Select Mail and Windows Computer
# 5. Copy the generated password and paste below
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=recipient@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# Health Check Thresholds (%)
CPU_THRESHOLD=80
RAM_THRESHOLD=85
DISK_THRESHOLD=90

# Backup Settings
BACKUP_DRIVE=D:\Backups
MAX_BACKUPS=7
